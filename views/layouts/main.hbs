<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="icon" type="image/x-icon" href="/images/studyo_white.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://unpkg.com/lenis@1.3.25/dist/lenis.css">
</head>
<body>
    <div class="app-shell">
        <main class="main-shell">
            <nav class="topbar navbar navbar-expand-lg navbar-light px-4 py-3">
                <a href="/" class="brand-badge text-dark me-3">
                    <span class="brand-mark">
                        <img src="/images/studyo_primary.png" alt="Studyo Logo">
                    </span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#topNav" aria-controls="topNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end" id="topNav">
                    <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">
                        <div class="navbar-nav ms-auto gap-1">
                            {{#unless session.user_id}}
                            <a href="/auth/login" class="nav-pill"><span><i class="bi bi-door-open"></i></span> Sign in</a>
                            {{else}}
                            <!-- Common Navigation -->
                            <a href="/course/list" class="nav-pill"><span><i class="bi bi-journal-text"></i></span> Courses</a>
                            <!-- Admin Navigation -->
                            {{#if (eq session.user_type "admin")}}
                            <a href="/mentor/list" class="nav-pill"><span><i class="bi bi-pen"></i></span> Mentors</a>
                            <a href="/learner/list" class="nav-pill"><span><i class="bi bi-pencil"></i></span> Learners</a>
                            <a href="/admin/list" class="nav-pill"><span><i class="bi bi-gear"></i></span> Admin</a>
                            {{/if}}
                        </div>
                        <div class="d-flex align-items-center gap-2 ms-2">
                            <div class="dropdown">
                                <button class="pfpBtn btn btn-sm rounded-circle text-white d-flex align-items-center justify-content-center" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false" style="width: 2.2rem; height: 2.2rem; font-weight: 700; border: none; padding: 0; overflow: hidden;">
                                    {{#if session.pfp}}
                                        <img src="/uploads/{{session.pfp}}" alt="{{session.name}}" style="width: 100%; height: 100%; object-fit: cover;">
                                    {{else}}
                                        {{session.name.[0]}}
                                    {{/if}}
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li><span class="dropdown-item-text small text-muted">{{session.name}}</span></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                                </ul>
                            </div>
                            {{/unless}}
                        </div>
                    </div>
                </div>
            </nav>

            <div class="p-4 p-lg-5">
                {{{ body }}}
            </div>
        </main>
    </div>

    <footer>
        <div class="text-light py-4">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <div class="text-center text-md-start">
                    &copy; 2024 Studyo. All rights reserved.
                </div>
                <div class="d-flex gap-3 justify-content-center">
                    <a href="#" class="text-light text-decoration-none">Privacy Policy</a>
                    <a href="#" class="text-light text-decoration-none">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lenis@1.3.25/dist/lenis.min.js"></script> 
    <script>new Lenis({ autoRaf: true, autoToggle: true, anchors: true, allowNestedScroll: true, naiveDimensions: true, stopInertiaOnNavigate: true })</script>
</body>
</html>