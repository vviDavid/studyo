<section class="page-shell">
    <div class="page-card overflow-hidden">
        <div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 p-4 border-bottom">
            <div>
                <h2 class="authTitle fw-bold mt-2 mb-1">List of Learners</h2>
                <p class="text-muted mb-0">We strive for a bit of insight.</p>
            </div>
            <a href="/learner/create" class="authSendBtn btn">
                <i class="bi bi-plus-lg me-2"></i>Add Learner
            </a>
        </div>

        <div class="row g-3">
            {{#each learner}}
            <div class="col-12 col-md-6 col-lg-4">
                <div class="page-card p-4 h-100 d-flex flex-column">
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div>
                            {{#if this.pfp}}
                            <img src="/uploads/{{this.pfp}}" alt="{{this.name}}" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover;">
                            {{else}}
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; color: white; font-weight: bold; font-size: 1.25rem;">{{this.name.[0]}}</div>
                            {{/if}}
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div class="fw-semibold">{{this.name}}</div>
                            <div class="small text-muted">{{this.email}}</div>
                        </div>
                    </div>

                    <div class="mb-3 pb-3 border-bottom flex-grow-1">
                        <div class="small mb-2">
                            {{#if this.grade}}
                            <span class="text-muted">Grade:</span>
                            <span class="pill pill-primary">{{this.grade}}</span>
                            {{/if}}
                        </div>
                        <div class="small text-muted mb-2">
                            <i class="bi bi-calendar-event me-2"></i>Created: {{this.created_at}}
                        </div>
                        {{#if this.updated_at}}
                        <div class="small text-muted">
                            <i class="bi bi-pencil me-2"></i>Updated: {{this.updated_at}}
                        </div>
                        {{/if}}
                    </div>

                    <div class="d-flex gap-2">
                        <a href="/learner/edit/{{this.id}}" class="btn btn-sm btn-outline-primary flex-grow-1">
                            <i class="bi bi-pencil-square me-1"></i>Edit
                        </a>
                        <form action="/learner/delete/{{this.id}}" method="POST" style="flex: 1;"
                            onsubmit="return confirm('Are you sure you want to delete this learner?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="col-12">
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
                    <p class="mb-0">No learner data available yet.</p>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>
