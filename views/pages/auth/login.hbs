<section class="auth-shell d-flex align-items-center justify-content-center py-5">
    <div class="auth-card p-4 p-md-5">
        <div class="text-center mb-4">
            <div class="mb-3">
                <img src="/images/studyo_primary.png" alt="Studyo" style="height: 60px; object-fit: contain;">
            </div>
            <h2 class="authTitle fw-bold mt-3 mb-2">Studyo</h2>
            <p class="text-muted mb-0">Your Studio for Studying.</p>
        </div>

        {{#if errorMessage}}
        <div class="alert-modern alert-error mb-4" role="alert">
            <div class="fw-semibold mb-2">Please fix the following issues:</div>
            <ul class="mb-0 ps-3">
                {{#each errorMessage}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>
        {{/if}}

        {{#if successMessage}}
        <div class="alert-modern alert-success mb-4" role="alert">
            <div class="fw-semibold mb-2">Success!</div>
            <ul class="mb-0 ps-3">
                {{#each successMessage}}
                {{this}}
                {{/each}}
            </ul>
        </div>
        {{/if}}

        <form action="/auth/login" method="POST" class="row g-3">
            <div class="col-12">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" class="form-control form-control-lg" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold">Password</label>
                <div class="password-field-wrapper">
                    <input type="password" class="form-control form-control-lg" id="pass" name="pass" placeholder="Enter your password" required>
                    <button type="button" class="password-toggle" id="passToggle">
                        <i class="bi bi-eye-slash"></i>
                    </button>
                </div>
            </div>
            <div class="col-12 d-flex justify-content-between align-items-center">
                <a href="/auth/forget-pass" class="authRedirBtn small text-decoration-none">I don't remember my password</a>
            </div>
            <div class="col-12">
                <button type="submit" class="authSendBtn btn w-100 btn-lg">Sign in</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a href="/" class="authRedirBtn small text-decoration-none">Back to Home</a>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const passToggle = document.getElementById('passToggle');
    const passInput = document.getElementById('pass');
    
    if (passToggle) {
        passToggle.addEventListener('click', function(e) {
            e.preventDefault();
            const icon = this.querySelector('i');
            if (passInput.type === 'password') {
                passInput.type = 'text';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            } else {
                passInput.type = 'password';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            }
        });
    }
});
</script>