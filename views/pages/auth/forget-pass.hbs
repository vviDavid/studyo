<section class="auth-shell d-flex align-items-center justify-content-center py-5">
    <div class="auth-card p-4 p-md-5">
        <div class="text-center mb-4">
            <div class="mb-3">
                <img src="/images/studyo_primary.png" alt="Studyo" style="height: 60px; object-fit: contain;">
            </div>
            <h2 class="authTitle fw-bold mt-3 mb-2">Forgot your password?</h2>
            <p class="text-muted mb-0">Worry not. We'll help you reset it.</p>
        </div>

        {{#if errorMessage}}
        <div class="alert-modern alert-error mb-4" role="alert">
            <div class="fw-semibold mb-2">Please fix the following issues:</div>
            <ul class="mb-0 ps-3">
                {{#each errorMessage}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>
        {{/if}}

        {{#if successMessage}}
        <div class="alert-modern alert-success mb-4" role="alert">
            <div class="fw-semibold mb-2">Success!</div>
            <ul class="mb-0 ps-3">
                {{#each successMessage}}
                {{this}}
                {{/each}}
            </ul>
        </div>
        {{/if}}

        <form action="/auth/forget-pass" method="POST" class="row g-3">
            <div class="col-12">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" class="form-control form-control-lg" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="col-12">
                <button type="submit" class="authSendBtn btn w-100 btn-lg">Send Recovery Link</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a href="/auth/login" class="authRedirBtn small text-decoration-none">Back to Login</a>
        </div>
    </div>
</section>
