<section class="page-shell">
    <div class="page-card p-4 p-lg-5">
        <div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-4">
            <div>
                <h2 class="authTitle fw-bold mt-2 mb-2">Delete {{course.course_name}}?</h2>
                <p class="text-muted mb-0">Remind yourself what you are about to do. Some changes remain eternal.</p>
            </div>
            <a href="/course/{{course.id}}/detail" class="btn btn-outline-secondary">Cancel</a>
        </div>

        {{#if errorMessage}}
        <div class="alert alert-error mb-4" role="alert">
            {{errorMessage}}
        </div>
        {{/if}}

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="page-card p-4 border border-danger-subtle">
                    <h5 class="fw-semibold text-danger mb-4">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirmation required
                    </h5>

                    <div class="alert alert-warning mb-4" role="alert">
                        <strong>Warning:</strong> Deleting this course will:
                        <ul class="mb-0 mt-2 ps-3">
                            <li>Remove all course contents</li>
                            <li>Unenroll all {{course.member_count}} learner(s)</li>
                            <li>Delete all comments</li>
                            <li>Remove all learner submissions and grades</li>
                        </ul>
                    </div>

                    <form action="/course/{{course.id}}/delete" method="POST" onsubmit="return confirm('Are you absolutely sure? This action cannot be undone.');">
                        <div class="d-flex gap-3">
                            <a href="/course/{{course.id}}/detail" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i>No, keep it
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-2"></i>Yes, delete permanently
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="page-card p-4">
                    <h5 class="authTitle fw-semibold mb-4">Course Details</h5>

                    <div class="stat-card p-3 mb-3">
                        {{#if course.course_pfp}}
                        <img src="/uploads/{{course.course_pfp}}" alt="{{course.course_name}}" class="rounded-2 mb-3" style="width: 100%; height: auto; max-height: 150px; object-fit: cover;">
                        {{/if}}
                        <div class="text-muted small mb-2">Course name</div>
                        <div class="fw-semibold">{{course.course_name}}</div>
                    </div>

                    <div class="stat-card p-3 mb-3">
                        <div class="text-muted small mb-2">Description</div>
                        <div class="small">{{course.course_desc}}</div>
                    </div>

                    <div class="stat-card p-3 mb-3">
                        <div class="text-muted small mb-2">Mentor</div>
                        <div class="fw-semibold">{{course.mentor_name}}</div>
                        <div class="small text-muted">{{course.mentor_email}}</div>
                    </div>

                    <div class="stat-card p-3">
                        <div class="text-muted small mb-2">Enrolled members</div>
                        <div class="display-6 fw-bold">{{course.member_count}}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>