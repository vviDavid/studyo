<section class="page-shell">
	<div class="page-card p-4 p-lg-5 w-100">
		<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-4">
			<div>
				<h2 class="authTitle fw-bold mt-2 mb-2">Create Course Group</h2>
				<p class="text-muted mb-0">{{course.course_name}}</p>
			</div>
			<a href="/course/{{course.id}}/detail#course-groups" class="btn btn-outline-secondary">Cancel</a>
		</div>

		{{#if errorMessage}}
		<div class="alert alert-error mb-4" role="alert">
			<div class="fw-semibold mb-2">Please fix the following errors:</div>
			<ul class="mb-0 ps-3">
				{{#each errorMessage}}
				<li>{{this}}</li>
				{{/each}}
			</ul>
		</div>
		{{/if}}

		<form action="/course/{{course.id}}/group/create" method="POST">
			<div class="page-card p-4">
				<h5 class="authTitle fw-semibold mb-4">Group Information</h5>

				<div class="mb-4">
					<label class="form-label fw-semibold">Name</label>
					<input type="text" class="form-control" name="group_name" value="{{formData.group_name}}" required>
					<small class="text-muted">Example: A Very Great Team in this Course (of course)</small>
				</div>

				<div class="mb-4">
					<label class="form-label fw-semibold d-block mb-3">Select Members</label>

					<div class="vertical-rack border rounded-3">
						{{#each courseMembers}}
						<label class="rack-item p-3 border-bottom d-flex align-items-center justify-content-between gap-3" style="cursor: pointer;">
							<div>
								<div class="fw-semibold">{{this.learner_name}}</div>
								<div class="small text-muted">{{this.learner_email}}</div>
							</div>
							<input class="form-check-input" type="checkbox" name="member_ids" value="{{this.id}}" {{isChecked ../formData.member_ids this.id}}>
						</label>
						{{else}}
						<div class="p-4 text-center text-muted">
							No enrolled members found in this course.
						</div>
						{{/each}}
					</div>

					<small class="text-muted d-block mt-2">You can only add learners in this course. Go away, strangers.</small>
				</div>

				<button type="submit" class="authSendBtn btn w-100">
					<i class="bi bi-people-fill me-2"></i>Create Group
				</button>
			</div>
		</form>
	</div>
</section>