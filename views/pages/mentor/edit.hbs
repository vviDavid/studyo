<section class="page-shell">
    <div class="page-card p-4 p-lg-5">
        <div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
            <div>
                <h2 class="authTitle fw-bold mt-2 mb-1">Update Mentor Details</h2>
                <p class="text-muted mb-0">Nothing stays constant. Changes are inevitable.</p>
            </div>
            <a href="/mentor/list" class="btn btn-outline-secondary">Back to List</a>
        </div>

        {{#if errorMessage}}
        <div class="alert-modern alert-error mb-4" role="alert">
            <div class="fw-semibold mb-2">Please fix the following issues:</div>
            <ul class="mb-0 ps-3">
                {{#each errorMessage}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>
        {{/if}}

        <form action="/mentor/edit/{{mentor.id}}" method="POST" enctype="multipart/form-data" class="row g-4">
            <div class="col-md-6">
                <label class="authTitle form-label fw-semibold">Name</label>
                <input type="text" class="form-control form-control-lg" id="name" name="name" value="{{mentor.name}}" required>
            </div>
            <div class="col-md-6">
                <label class="authTitle form-label fw-semibold">Email</label>
                <input type="email" class="form-control form-control-lg" id="email" name="email" value="{{mentor.email}}" required>
            </div>
            <div class="col-md-6">
                <label class="authTitle form-label fw-semibold">Expertise</label>
                <input type="text" class="form-control form-control-lg" id="expertise" name="expertise" value="{{mentor.expertise}}">
            </div>
            <div class="col-md-6">
                <label class="authTitle form-label fw-semibold">Birthday</label>
                <input type="date" class="form-control form-control-lg" id="birthday" name="birthday" value="{{mentor.birthday}}">
            </div>
            <div class="col-12">
                <label class="authTitle form-label fw-semibold">Profile Picture</label>
                <div id="imagePreview" class="image-preview rounded-3 bg-light p-3 text-center mb-3" style="min-height: 120px; display: flex; align-items: center; justify-content: center;">
                    {{#if mentor.pfp}}
                    <img src="/uploads/{{mentor.pfp}}" alt="Current profile" style="max-width: 100%; max-height: 150px;">
                    {{else}}
                    <div class="text-muted">
                        <i class="bi bi-image" style="font-size: 2rem;"></i>
                        <p class="mb-0 small mt-2">No image</p>
                    </div>
                    {{/if}}
                </div>
                <input type="file" class="form-control form-control-lg" id="pfp" name="pfp" accept="image/*">
                <input type="hidden" name="removePhoto" id="removePhoto" value="0">
                <button type="button" class="btn btn-outline-secondary btn-sm mt-2" id="clearPhotoBtn">Remove current photo</button>
            </div>
            <div class="col-12 d-flex justify-content-end gap-2">
                <a href="/mentor/list" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="authSendBtn btn btn-primary">Save Changes</button>
            </div>
        </form>

        <script>
            const pfpInput = document.getElementById('pfp');
            const previewBox = document.getElementById('imagePreview');
            const clearPhotoBtn = document.getElementById('clearPhotoBtn');
            const removePhotoField = document.getElementById('removePhoto');
            
            if (pfpInput) {
                pfpInput.addEventListener('change', function () {
                    const file = this.files && this.files[0];
                    const preview = document.getElementById('imagePreview');
                    
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (event) {
                            preview.innerHTML = `<img src="${event.target.result}" alt="Preview" style="max-width: 100%; max-height: 150px;">`;
                        };
                        reader.readAsDataURL(file);
                    }
                });
            }

            if (clearPhotoBtn) {
                clearPhotoBtn.addEventListener('click', function () {
                    pfpInput.value = '';
                    const preview = document.getElementById('imagePreview');
                    preview.innerHTML = `
                        <div class="text-muted">
                            <i class="bi bi-image" style="font-size: 2rem;"></i>
                            <p class="mb-0 small mt-2">No image</p>
                        </div>
                    `;
                    removePhotoField.value = '1';
                });
            }
        </script>
    </div>
</section>
