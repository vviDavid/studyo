<section class="page-shell">
	<div class="page-card p-4 p-lg-5 text-center">
		<div class="mx-auto mb-4 d-flex align-items-center justify-content-center rounded-circle" style="width: 88px; height: 88px; background: rgba(180, 35, 24, 0.12); color: var(--alert);">
			<i class="bi bi-exclamation-triangle-fill" style="font-size: 2rem;"></i>
		</div>

		<h1 class="authTitle fw-bold mb-2">
			{{#if title}}{{title}}{{else}}Something went wrong{{/if}}
		</h1>

		<p class="text-muted mb-4 mx-auto" style="max-width: 640px;">
			{{#if message}}
				{{message}}
			{{else}}
				We hit an unexpected issue while loading this page. Please try again, or go back to a safe page.
			{{/if}}
		</p>

		<div class="d-flex flex-column flex-sm-row justify-content-center gap-2 mb-4">
			<button type="button" class="btn btn-outline-primary" onclick="window.location.reload();">
				<i class="bi bi-arrow-clockwise me-2"></i>Try Again
			</button>
			<a href="/course/list" class="btn btn-outline-secondary">
				<i class="bi bi-journal-text me-2"></i>Go to Courses
			</a>
			<a href="/" class="btn authSendBtn">
				<i class="bi bi-house-door me-2"></i>Back to Home
			</a>
		</div>

		{{#if errorCode}}
		<div class="small text-muted">
			Error code: <span class="fw-semibold">{{errorCode}}</span>
		</div>
		{{/if}}
	</div>
</section>