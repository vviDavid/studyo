<section class="page-shell">
	<div class="page-card p-4 p-lg-5" style="max-width: 760px; margin: 0 auto;">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h2 class="authTitle fw-bold mb-0">My Profile</h2>
		</div>

		{{#if successMessage}}
		<div class="alert alert-success mb-4" role="alert">{{successMessage}}</div>
		{{/if}}

		<div class="d-flex flex-column align-items-center gap-4">
			<div class="rounded-circle border overflow-hidden d-flex align-items-center justify-content-center" style="width: 136px; height: 136px; background: #eef2ff;">
				{{#if profile.pfp}}
				<img src="/uploads/{{profile.pfp}}" alt="{{profile.name}}" style="width: 100%; height: 100%; object-fit: cover;">
				{{else}}
				<span class="authTitle fw-bold" style="font-size: 2.6rem; color: #4f46e5;">{{profile.name.[0]}}</span>
				{{/if}}
			</div>

			<div class="vertical-rack w-100" style="max-width: 560px;">
				<div class="rack-item p-3">
					<div class="small text-muted mb-1">Name</div>
					<div class="fw-semibold">{{profile.name}}</div>
				</div>

				<div class="rack-item p-3">
					<div class="small text-muted mb-1">Email</div>
					<div class="fw-semibold">{{profile.email}}</div>
				</div>

				{{#if (eq profile.user_type "mentor")}}
				<div class="rack-item p-3">
					<div class="small text-muted mb-1">Expertise</div>
					<div class="fw-semibold">{{#if profile.expertise}}{{profile.expertise}}{{else}}-{{/if}}</div>
				</div>
				{{/if}}

				{{#if (eq profile.user_type "learner")}}
				<div class="rack-item p-3">
					<div class="small text-muted mb-1">Grade</div>
					<div class="fw-semibold">{{#if profile.grade}}{{profile.grade}}{{else}}-{{/if}}</div>
				</div>
				{{/if}}

				<div class="rack-item p-3">
					<div class="small text-muted mb-1">Birthday</div>
					<div class="fw-semibold">{{#if profile.birthday}}{{profile.birthday}}{{else}}-{{/if}}</div>
				</div>
			</div>

			<a href="/profile/edit" class="authSendBtn btn px-4">Edit Profile</a>
		</div>
	</div>
</section>